# Database Configuration
# Replace POSTGRES_USER and POSTGRES_PASSWORD with your actual credentials
DATABASE_URL=postgresql://POSTGRES_USER:POSTGRES_PASSWORD@db:5432/kikdb

# PostgreSQL Configuration
# IMPORTANT: Use strong, unique passwords in production
POSTGRES_USER=xxx
POSTGRES_PASSWORD=xxx
POSTGRES_DB=kikdb

# CORS Configuration (optional)
# Comma-separated list of allowed origins for Socket.io connections
# Example: ALLOWED_ORIGINS=https://example.com,https://app.example.com
# Leave empty or use '*' to allow all origins (not recommended for production)
ALLOWED_ORIGINS=

# Site Configuration (optional)
# Canonical public URL used to build absolute links in sitemap.xml
# Defaults to https://www.kino-im-kasten.de if not set
NUXT_PUBLIC_SITE_URL=https://www.kino-im-kasten.de

# Does the dog die api key
DDD_API_KEY=
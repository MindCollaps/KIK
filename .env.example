# Database Configuration
# Replace POSTGRES_USER and POSTGRES_PASSWORD with your actual credentials
DATABASE_URL=postgresql://POSTGRES_USER:POSTGRES_PASSWORD@db:5432/kikdb

# PostgreSQL Configuration
# IMPORTANT: Use strong, unique passwords in production
POSTGRES_USER=xxx
POSTGRES_PASSWORD=xxx
POSTGRES_DB=kikdb

# CORS Configuration (optional)
# Comma-separated list of allowed origins for Socket.io connections
# Example: ALLOWED_ORIGINS=https://example.com,https://app.example.com
# Leave empty or use '*' to allow all origins (not recommended for production)
ALLOWED_ORIGINS=

# Site Configuration (optional)
# Canonical public URL used to build absolute links in sitemap.xml
# Defaults to https://www.kino-im-kasten.de if not set
NUXT_PUBLIC_SITE_URL=https://www.kino-im-kasten.de

# Does the dog die api key
DDD_API_KEY=

# Mail / SMTP Configuration
# Used for account invitations and password reset mails.
# NUXT_MAIL_ENABLED=false disables all outgoing mails. Accounts are then created
# without an invitation and an admin must set the password manually.
NUXT_MAIL_ENABLED=true
# NUXT_MAIL_LOG=true logs the content of every outgoing mail to the console.
# Recommended: true in development, false in production.
NUXT_MAIL_LOG=false
# If NUXT_SMTP_HOST is empty, mails are not sent but logged to the console (development).
NUXT_SMTP_HOST=
NUXT_SMTP_PORT=587
# Set to 'true' for implicit TLS (usually port 465), leave empty for STARTTLS
NUXT_SMTP_SECURE=
NUXT_SMTP_USER=
NUXT_SMTP_PASS=
# Sender shown in outgoing mails
NUXT_SMTP_FROM=Kino im Kasten <noreply@kino-im-kasten.de>
datasource db {
  provider = "postgres"
}

generator client {
  provider = "prisma-client-js"
}

enum ProgramStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  HIDDEN
}

enum ProgramStyle {
  DEFAULT
  SPECIAL
  HIGHLIGHTED
  CUSTOM
}

enum PageStatus {
  DRAFT
  PUBLISHED
}

enum Permission {
  PAGES
  PROGRAM
  SETTINGS
  KASSE_USE
  KASSE_REPORTS
  KASSE_REPORTS_EDIT
  KASSE_MANAGE
  USERS
}

model Page {
  id          String     @id @default(uuid())
  slug        String     @unique
  title       String
  description String?
  theme       String     @default("info")
  status      PageStatus @default(PUBLISHED)
  blocks      Json
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([status])
}

model SiteSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

model AdminUser {
  id               String           @id @default(uuid())
  email            String           @unique
  name             String
  passwordHash     String
  permissions      Permission[]     @default([])
  active           Boolean          @default(true)
  lastLoginAt      DateTime?
  emailConfirmedAt DateTime?
  sessions         AdminSession[]
  tokens           AdminUserToken[]
  bonsCreated     Bon[]           @relation("BonCreatedBy")
  bonsCancelled   Bon[]           @relation("BonCancelledBy")
  tagesabschluesse Tagesabschluss[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

enum AdminTokenType {
  INVITE
  PASSWORD_RESET
}

model AdminUserToken {
  id        String         @id @default(uuid())
  tokenHash String         @unique
  type      AdminTokenType
  expiresAt DateTime
  userId    String
  user      AdminUser      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model AdminSession {
  id        String    @id @default(uuid())
  tokenHash String    @unique
  expiresAt DateTime
  userId    String
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model SetupState {
  key       String   @id
  createdAt DateTime @default(now())
}

enum BonStatus {
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
}

enum StoreLogType {
  CATEGORY_CREATED
  CATEGORY_UPDATED
  CATEGORY_DELETED
  ITEM_CREATED
  ITEM_UPDATED
  ITEM_DELETED
  BON_CREATED
  BON_UPDATED
  BON_DELETED
  BON_CANCELLED
  TAGESABSCHLUSS_CREATED
  TAGESABSCHLUSS_UPDATED
  POOL_CREATED
  POOL_UPDATED
  POOL_DELETED
}

// Nummernpool: gruppiert Artikel, die sich einen fortlaufenden Nummernkreis
// teilen (z. B. Kinokarten normal/ermäßigt vom selben physischen Kartenblock)
model NumberPool {
  id         String      @id @default(uuid())
  name       String
  nextNumber Int?
  items      StoreItem[]
  bonItems   BonItem[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model StoreCategory {
  id        String      @id @default(uuid())
  name      String
  color     String?
  icon      String?
  sortOrder Int         @default(0)
  archived  Boolean     @default(false)
  items     StoreItem[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model StoreItem {
  id         String        @id @default(uuid())
  categoryId String
  category   StoreCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  name       String
  priceCents Int           @default(0)
  freePrice  Boolean       @default(false)
  numberPoolId String?
  numberPool NumberPool?   @relation(fields: [numberPoolId], references: [id], onDelete: SetNull)
  color      String?
  sortOrder  Int           @default(0)
  archived   Boolean       @default(false)
  bonItems  BonItem[]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([categoryId])
  @@index([numberPoolId])
}

model Bon {
  number           Int             @id @default(autoincrement())
  status           BonStatus      @default(COMPLETED)
  paymentMethod    PaymentMethod
  totalCents       Int
  items            BonItem[]
  createdById      String?
  createdBy        AdminUser?      @relation("BonCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdByName    String
  createdAt        DateTime        @default(now())
  cancelledAt      DateTime?
  cancelledById    String?
  cancelledBy      AdminUser?      @relation("BonCancelledBy", fields: [cancelledById], references: [id], onDelete: SetNull)
  cancelledByName  String?
  cancelReason     String?
  tagesabschlussId Int?
  tagesabschluss   Tagesabschluss? @relation(fields: [tagesabschlussId], references: [number], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([tagesabschlussId])
}

model BonItem {
  id             String     @id @default(uuid())
  bonNumber     Int
  bon           Bon       @relation(fields: [bonNumber], references: [number], onDelete: Cascade)
  itemId         String?
  item           StoreItem? @relation(fields: [itemId], references: [id], onDelete: SetNull)
  name           String
  unitPriceCents Int
  quantity       Int
  firstNumber    Int?
  lastNumber     Int?
  numberPoolId   String?
  numberPool     NumberPool? @relation(fields: [numberPoolId], references: [id], onDelete: SetNull)

  @@index([bonNumber])
  @@index([itemId])
  @@index([numberPoolId])
}

model Tagesabschluss {
  number            Int        @id @default(autoincrement())
  periodStart       DateTime
  periodEnd         DateTime
  openingCashCents  Int
  countedCashCents  Int
  expectedCashCents Int
  differenceCents   Int
  revenueCents      Int
  cashRevenueCents  Int
  cardRevenueCents  Int
  bonCount         Int
  stornoCount       Int
  stornoTotalCents  Int
  cashDifferenceReason String?
  breakdown         Json
  numberedBreakdown Json?
  bons             Bon[]
  createdById       String?
  createdBy         AdminUser? @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdByName     String
  createdAt         DateTime   @default(now())
}

model StoreAuditLog {
  id         String       @id @default(uuid())
  type       StoreLogType
  actorId    String?
  actorName  String
  bonNumber Int?
  details    Json
  createdAt  DateTime     @default(now())

  @@index([createdAt])
  @@index([type])
}

model ProgramEntry {
  id             String        @id @default(uuid())
  title          String
  description    String
  startsAt       DateTime
  venue          String?
  language       String?
  runtimeMinutes Int?
  ageRating      String?
  director       String?
  country        String?
  releaseYear    Int?
  infoUrl        String?
  priceCents     Int?
  isFree         Boolean       @default(false)
  style          ProgramStyle  @default(DEFAULT)
  highlightColor String?
  customBadgeText String?
  customBadgeBorder Boolean     @default(false)
  customBadgeIcon String?
  customCardBorder Boolean     @default(false)
  imagePath      String?
  imageAlt       String?
  doesTheDogDieId Int?
  contentWarnings Json?
  contentWarningsUpdatedAt DateTime?
  status         ProgramStatus @default(DRAFT)
  visibleFrom    DateTime?
  visibleUntil   DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([status, startsAt])
  @@index([status, visibleFrom, visibleUntil])
  @@index([doesTheDogDieId])
}


{
  "name": "kik",
  "type": "module",
  "private": true,
  "version": "0.5.0",
  "scripts": {
    "build": "nuxt build",
    "dev": "UID=$(id -u) GID=$(id -g) docker compose -f docker-compose.yml -f docker-compose.dev.yml up --build",
    "dev:down": "docker compose -f docker-compose.yml -f docker-compose.dev.yml down",
    "dev:local": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "prepare": "nuxt prepare",
    "postinstall": "nuxt prepare",
    "lint:ts": "eslint .",
    "lint:ts:fix": "eslint . --fix",
    "stylelint": "stylelint --config stylelint.config.js --max-warnings=0 './app/**/*.{vue,scss,css}'",
    "stylelint:fix": "stylelint --config stylelint.config.js --fix './app/**/*.{vue,scss,css}'",
    "lint:fix": "bun run stylelint:fix && bun run lint:ts:fix",
    "lint": "bun run stylelint && bun run lint:ts",
    "db-push": "docker compose -f docker-compose.yml -f docker-compose.dev.yml exec kik-app bun run prisma db push",
    "db-deploy": "docker compose -f docker-compose.yml -f docker-compose.dev.yml exec kik-app bun run prisma migrate deploy",
    "db-drop": "docker compose -f docker-compose.yml -f docker-compose.dev.yml exec kik-app bun run prisma db push --force-reset",
    "db-reset-db": "docker compose -f docker-compose.yml -f docker-compose.dev.yml exec kik-app sh -c \"bun run prisma migrate reset --force && bun run prisma migrate dev --name init && bun run prisma generate\"",
    "db-reset": "rm -rf ./prisma/migrations && bun run db-reset-db"
  },
  "dependencies": {
    "@iconify-json/mdi": "^1.2.3",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/icon": "^2.3.1",
    "@nuxt/image": "^2.0.0",
    "@nuxt/scripts": "^1.3.1",
    "@pinia/nuxt": "^0.11.3",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "animejs": "^4.5.0",
    "exceljs": "^4.4.0",
    "handlebars": "^4.7.9",
    "jsonwebtoken": "^9.0.3",
    "markdown-it": "^14.3.0",
    "nodemailer": "^9.0.3",
    "nuxt": "^4.4.8",
    "pdfmake": "^0.2.20",
    "pinia": "^3.0.4",
    "prisma": "^7.8.0",
    "uuid": "^14.0.1",
    "vue": "^3.5.40",
    "vue-router": "^5.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@iconify-json/material-symbols": "^1.2.85",
    "@nuxt/devtools": "^4.0.0-alpha.7",
    "@nuxt/eslint": "^1.16.0",
    "@nuxtjs/stylelint-module": "^5.2.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@stylistic/stylelint-plugin": "^5.2.1",
    "@types/cookie": "^1.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/markdown-it": "^14.1.2",
    "@types/nodemailer": "^8.0.1",
    "@types/pdfmake": "^0.3.3",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.9.2",
    "postcss": "^8.5.19",
    "postcss-html": "^1.8.1",
    "prettier": "^3.9.5",
    "sass-embedded": "^1.100.0",
    "stylelint": "^17.14.0",
    "stylelint-config-clean-order": "^8.0.2",
    "stylelint-config-recommended-scss": "^17.0.1",
    "stylelint-config-recommended-vue": "^1.6.1",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-order": "^8.1.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vite-plugin-eslint2": "^5.3.0",
    "vue-tsc": "^3.3.7"
  }
}
